<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ═══════════════════════════════════════════════════════
       IDENTITY
       Replace the Id GUID with a newly generated one if
       you fork this add-in for a different deployment.
  ═══════════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Joeymeijer.nl</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="Send Securely" />
  <Description DefaultValue="Send email content as a self-destructing secret link via Hemmelig." />

  <IconUrl DefaultValue="https://joeymeijer.nl/add-in/assets/icon-80.png" />
  <HighResolutionIconUrl DefaultValue="https://joeymeijer.nl/add-in/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://secret.joeymeijer.nl" />

  <!-- ═══════════════════════════════════════════════════════
       PERMISSIONS & RULES
       ReadWriteItem lets us read and replace the email body.
  ═══════════════════════════════════════════════════════ -->
  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <!-- Activate in compose mode for new messages and replies -->
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- ═══════════════════════════════════════════════════════
       VERSION OVERRIDES (Ribbon button + Task pane)
       Requires Exchange 2016+ / Outlook 2016+ / OWA
  ═══════════════════════════════════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">

        <!-- ── Desktop Outlook ──────────────────────── -->
        <DesktopFormFactor>

          <!-- Function file (ribbon command handler) -->
          <FunctionFile resid="Commands.Url" />

          <!-- Compose message extension point (adds our ribbon button) -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="Hemmelig.Group">
                <Label resid="Group.Label" />

                <!-- "Send Securely" ribbon button -->
                <Control xsi:type="Button" id="Hemmelig.SendSecurely">
                  <Label resid="Button.Label" />
                  <Supertip>
                    <Title resid="Button.Title" />
                    <Description resid="Button.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16"  resid="Icon.16x16"  />
                    <bt:Image size="32"  resid="Icon.32x32"  />
                    <bt:Image size="80"  resid="Icon.80x80"  />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>Hemmelig.Taskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                    <Title resid="Button.Label" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>

      </Host>
    </Hosts>

    <!-- ── Resource strings ────────────────────────── -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://joeymeijer.nl/add-in/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://joeymeijer.nl/add-in/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://joeymeijer.nl/add-in/assets/icon-80.png" />
      </bt:Images>

      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://joeymeijer.nl/add-in/commands.html" />
        <bt:Url id="Taskpane.Url"  DefaultValue="https://joeymeijer.nl/add-in/taskpane.html" />
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="Group.Label"    DefaultValue="Hemmelig" />
        <bt:String id="Button.Label"   DefaultValue="Send Securely" />
        <bt:String id="Button.Title"   DefaultValue="Send Securely via Hemmelig" />
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="Button.Tooltip" DefaultValue="Encrypt your email content as a self-destructing secret link on secret.joeymeijer.nl and replace the message body with the secure URL." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
